---
// Trust features grid with dynamic translations — 3 cards (delivery, COD, verified product).
import { useTranslations } from "../data/translations";

const locale = Astro.currentLocale || "fr";
const t = useTranslations(locale);

const features = [
  {
    icon: "📦",
    titleKey: "trust.delivery.title" as const,
    descKey: "trust.delivery.desc" as const,
    highlight: false,
  },
  {
    icon: "🤝",
    titleKey: "trust.cod.title" as const,
    descKey: "trust.cod.desc" as const,
    highlight: true,
  },
  {
    icon: "✅",
    titleKey: "trust.guaranteed.title" as const,
    descKey: "trust.guaranteed.desc" as const,
    highlight: false,
  },
];
---

<section id="why-us" class="bg-surface-container-lowest px-gutter py-section-padding">
  <div class="mx-auto max-w-container-max">
    <div class="mb-16 text-center">
      <h2 class="mb-4 text-headline-md font-bold text-on-background">
        {t("trust.title")}
      </h2>
      <p class="text-body-md text-on-surface-variant">
        {t("trust.subtitle")}
      </p>
    </div>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      {
        features.map((f) => (
          <div
            class:list={[
              "glass-card flex flex-col items-center gap-4 rounded-xl p-8 text-center",
              f.highlight && "border-accent/20 bg-accent-tint/30",
            ]}
          >
            <div
              class:list={[
                "mb-2 flex h-16 w-16 items-center justify-center rounded-full text-3xl",
                f.highlight ? "bg-accent-tint" : "bg-surface-container",
              ]}
            >
              {f.icon}
            </div>
            <h3 class="text-lg font-bold text-on-background">{t(f.titleKey)}</h3>
            <p class="mt-2 text-sm text-secondary">{t(f.descKey)}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
