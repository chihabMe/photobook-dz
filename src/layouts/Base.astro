---
// Base layout: html shell, self-hosted fonts, Material Symbols, SEO meta.
import "@fontsource/plus-jakarta-sans/400.css";
import "@fontsource/plus-jakarta-sans/600.css";
import "@fontsource/plus-jakarta-sans/700.css";
import "@fontsource/plus-jakarta-sans/800.css";
import "../styles/tokens.css";

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Photobook dz — Albums photo premium livrés en Algérie",
  description =
    "Créez votre photobook premium à couverture bois gravée. Livraison 58 wilayas, paiement à la livraison (COD), produit vérifié avant paiement.",
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0f172a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph / social preview -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="fr_DZ" />

    <!-- Material Symbols (icon font). Self-hosting later in the polish pass. -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap"
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <slot />
  </body>
</html>
