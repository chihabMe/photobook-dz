---
// Base layout: html shell, self-hosted fonts, Material Symbols, SEO meta.
import "@fontsource/plus-jakarta-sans/400.css";
import "@fontsource/plus-jakarta-sans/600.css";
import "@fontsource/plus-jakarta-sans/700.css";
import "@fontsource/plus-jakarta-sans/800.css";
import "../styles/tokens.css";
import { useTranslations } from "../data/translations";

export interface Props {
  title?: string;
  description?: string;
}

const locale = Astro.currentLocale || "fr";
const dir = locale === "ar" ? "rtl" : "ltr";
const t = useTranslations(locale);

const {
  title = t("meta.title"),
  description = t("meta.desc"),
} = Astro.props;
---

<!doctype html>
<html lang={locale} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0f172a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph / social preview -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={locale === "ar" ? "ar_DZ" : locale === "en" ? "en_US" : "fr_DZ"} />

    <!-- Fonts: Load Cairo font specifically for beautiful Arabic typography -->
    {locale === "ar" && (
      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet" />
    )}

    <style is:global>
      /* Apply Cairo font override if Arabic */
      html[lang="ar"], html[lang="ar"] body, html[lang="ar"] button, html[lang="ar"] select, html[lang="ar"] input {
        font-family: 'Cairo', 'Plus Jakarta Sans', sans-serif !important;
      }
    </style>

    <!-- Material Symbols (icon font). Self-hosting later in the polish pass. -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap"
    />
  </head>
  <body class="min-h-screen flex flex-col bg-background text-on-background">
    <slot />
  </body>
</html>
