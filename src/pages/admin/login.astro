---
import { createHash } from "node:crypto";
import Base from "../../layouts/Base.astro";

export const prerender = false;

const ADMIN_PASSWORD = process.env.ADMIN_PASSWORD || "admin";
const passwordHash = createHash("sha256").update(ADMIN_PASSWORD).digest("hex");

let loginError = false;

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const action = formData.get("action");

  if (action === "logout") {
    Astro.cookies.delete("admin_token", { path: "/" });
  } else {
    const password = formData.get("password") as string;
    const inputHash = createHash("sha256").update(password).digest("hex");
    if (inputHash === passwordHash) {
      Astro.cookies.set("admin_token", passwordHash, { path: "/", maxAge: 60 * 60 * 24 });
      return Astro.redirect("/admin/orders");
    } else {
      loginError = true;
    }
  }
}
---

<Base title="Photobook dz — Connexion Admin" description="Accédez au panneau d'administration.">
  <main class="min-h-screen bg-slate-100 flex items-center justify-center p-6">
    <div class="w-full max-w-md rounded-xl border border-slate-200 bg-white p-8 shadow-xl">
      <div class="mb-6 text-center">
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-slate-100 text-slate-700 mb-2">
          <span class="material-symbols-outlined">admin_panel_settings</span>
        </span>
        <h1 class="text-headline-md font-bold text-slate-900">Admin Access</h1>
        <p class="text-body-md text-slate-500">Veuillez saisir votre mot de passe pour continuer.</p>
      </div>

      <form method="POST" class="space-y-4">
        <div>
          <label htmlFor="password" class="mb-2 block text-label-bold font-bold text-slate-700">Mot de passe / Password</label>
          <input 
            id="password" 
            name="password" 
            type="password" 
            required 
            placeholder="••••••••" 
            class="w-full rounded-md border border-slate-300 bg-white px-4 py-3 text-body-md text-slate-900 outline-none focus:border-primary focus:ring-1 focus:ring-primary"
          />
          {loginError && (
            <p class="mt-2 text-sm text-error font-semibold">Mot de passe incorrect.</p>
          )}
        </div>
        <button 
          type="submit" 
          class="flex w-full items-center justify-center rounded-md bg-primary py-3 text-button-text font-semibold text-white shadow-md hover:bg-primary-dark transition-colors"
        >
          Se connecter
        </button>
      </form>
    </div>
  </main>
</Base>
